{
  "title": "Home Environment",
  "uid": "home-environment",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["home", "environment"],
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "location",
        "label": "Location",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-home" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"environment\", tag: \"location\")",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Temperature",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-home" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 18 },
              { "color": "yellow","value": 25 },
              { "color": "red",   "value": 28 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-home" },
          "query": "from(bucket: \"environment\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"environment\")\n  |> filter(fn: (r) => r._field == \"temperature_c\")\n  |> filter(fn: (r) => r.location =~ /^${location:regex}$/)\n  |> last()"
        }
      ]
    },
    {
      "id": 2,
      "title": "Humidity",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-home" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "humidity",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green",  "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "red",    "value": 70 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-home" },
          "query": "from(bucket: \"environment\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"environment\")\n  |> filter(fn: (r) => r._field == \"humidity_rh\")\n  |> filter(fn: (r) => r.location =~ /^${location:regex}$/)\n  |> last()"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pressure",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-home" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "hPa",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 980 },
              { "color": "blue",  "value": 1030 }
            ]
          },
          "mappings": [],
          "custom": {}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-home" },
          "query": "from(bucket: \"environment\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"environment\")\n  |> filter(fn: (r) => r._field == \"pressure_hpa\")\n  |> filter(fn: (r) => r.location =~ /^${location:regex}$/)\n  |> last()"
        }
      ]
    },
    {
      "id": 10,
      "title": "Temperature over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-home" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "min", "max", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-home" },
          "query": "from(bucket: \"environment\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"environment\")\n  |> filter(fn: (r) => r._field == \"temperature_c\")\n  |> filter(fn: (r) => r.location =~ /^${location:regex}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.location }))"
        }
      ]
    },
    {
      "id": 11,
      "title": "Humidity over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-home" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "min", "max", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "humidity",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green",  "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "red",    "value": 70 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-home" },
          "query": "from(bucket: \"environment\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"environment\")\n  |> filter(fn: (r) => r._field == \"humidity_rh\")\n  |> filter(fn: (r) => r.location =~ /^${location:regex}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.location }))"
        }
      ]
    },
    {
      "id": 12,
      "title": "Pressure over time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-home" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "min", "max", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "hPa",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          },
          "overrides": []
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-home" },
          "query": "from(bucket: \"environment\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"environment\")\n  |> filter(fn: (r) => r._field == \"pressure_hpa\")\n  |> filter(fn: (r) => r.location =~ /^${location:regex}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.location }))"
        }
      ]
    }
  ]
}
