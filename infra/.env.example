# Copy to .env and fill in values — never commit .env

# InfluxDB initial setup (only used on first start)
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=changeme_strong_password
INFLUXDB_ORG=home
INFLUXDB_BUCKET=environment
INFLUXDB_ADMIN_TOKEN=changeme_generate_with_openssl_rand_hex_32

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
